rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tenants/{tenantId}/bookings/{docId} {
      allow read: if true;
      allow create: if true;
      allow delete: if request.auth != null;
      allow update: if request.auth != null
        || (
          resource.data.clientEmail != null
          && resource.data.clientEmail != ''
          && request.resource.data.clientEmail == resource.data.clientEmail
          && request.resource.data.bookingId == resource.data.bookingId
        );
    }
    match /tenants/{tenantId}/{collection}/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
